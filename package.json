{
  "name": "forge",
  "version": "0.1.0",
  "private": true,
  "description": "Forge — a compiled, signal-first JavaScript framework for enterprise apps",
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs"
  ],
  "scripts": {
    "build": "nx run-many --target=build --exclude=docs",
    "test": "nx run-many --target=test --exclude=docs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "nx run-many --target=lint --exclude=docs",
    "typecheck": "nx run-many --target=typecheck --exclude=docs",
    "clean": "nx run-many --target=clean && rm -rf node_modules",
    "graph": "nx graph",
    "docs:dev": "nx run docs:dev",
    "docs:build": "nx run docs:build",
    "docs:preview": "nx run docs:preview"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "happy-dom": "^20.8.4",
    "nx": "^22.6.1",
    "rolldown": "^0.14.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
