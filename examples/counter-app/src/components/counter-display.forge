<script>
import { inject } from '@forge/core';
import { CounterService } from '../services/counter.service.js';

const svc = inject(CounterService);
const count = svc.count;
const doubled = svc.doubled;
</script>

<template>
  <div class="my-4">
    <p class="text-6xl font-bold text-gray-900 mb-1">{count()}</p>
    <p class="text-sm text-gray-400">Doubled: {doubled()}</p>
  </div>
</template>
