{
  "name": "@forge/forms",
  "version": "0.1.0",
  "description": "Forge forms — signal-based reactive forms",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
