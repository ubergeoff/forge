{
  "name": "@forge/forms",
  "version": "0.1.0",
  "description": "Forge forms — signal-based reactive forms",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ubergeoff/forge.git",
    "directory": "packages/forms"
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.mjs",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "peerDependencies": {
    "@forge/core": "^0.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
