{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@forge/forms",
  "projectType": "library",
  "implicitDependencies": ["@forge/core"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rolldown -c rolldown.config.mjs",
        "cwd": "{projectRoot}"
      },
      "dependsOn": [{ "projects": ["@forge/core"], "target": "build" }]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run packages/forms/__tests__",
        "cwd": "{workspaceRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --build packages/forms/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src --ext .ts",
        "cwd": "{projectRoot}"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf dist .tsbuildinfo",
        "cwd": "{projectRoot}"
      }
    }
  }
}
