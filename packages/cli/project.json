{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@forge/cli",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rolldown -c rolldown.config.mjs",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --build packages/cli/tsconfig.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src --ext .ts",
        "cwd": "{projectRoot}"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf dist .tsbuildinfo",
        "cwd": "{projectRoot}"
      }
    }
  }
}
