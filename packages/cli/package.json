{
  "name": "@forge/cli",
  "version": "0.1.0",
  "description": "Forge CLI — forge new / forge dev / forge build",
  "license": "MIT",
  "type": "module",
  "bin": {
    "forge": "./dist/bin.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ubergeoff/forge.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.mjs",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@forge/compiler": "^0.1.0",
    "rolldown": "^0.14.0"
  },
  "devDependencies": {
    "typescript": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
