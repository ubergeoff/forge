{
  "name": "@forge/cli",
  "version": "0.1.0",
  "description": "Forge CLI — forge new / forge dev / forge build",
  "type": "module",
  "bin": {
    "forge": "./dist/bin.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.mjs",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@forge/compiler": "*",
    "rolldown": "*"
  },
  "devDependencies": {
    "typescript": "*"
  }
}
