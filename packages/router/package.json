{
  "name": "@forge/router",
  "version": "0.1.0",
  "description": "Forge router — signal-driven client-side routing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.mjs",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@forge/core": "*"
  },
  "devDependencies": {
    "rolldown": "*",
    "typescript": "*",
    "vitest": "*"
  },
  "sideEffects": false
}
