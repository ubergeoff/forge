{
  "name": "@forge/compiler",
  "version": "0.1.0",
  "description": "Forge compiler — .forge SFC parser and template compiler",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ubergeoff/forge.git",
    "directory": "packages/compiler"
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.mjs",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@forge/core": "^0.1.0",
    "oxc-transform": "^0.121.0"
  },
  "peerDependencies": {
    "postcss": ">=8.4.0",
    "sass": ">=1.57.0"
  },
  "peerDependenciesMeta": {
    "postcss": {
      "optional": true
    },
    "sass": {
      "optional": true
    }
  },
  "devDependencies": {
    "rolldown": "*",
    "sass": "*",
    "typescript": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
