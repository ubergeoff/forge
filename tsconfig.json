{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "composite": true
  },
  "exclude": ["**/node_modules", "**/dist"],
  "paths": {
    "@forge/core": ["packages/core/src/index.ts"],
    "@forge/compiler": ["packages/compiler/src/index.ts"],
    "@forge/cli": ["packages/cli/src/index.ts"],
    "@forge/router": ["packages/router/src/index.ts"],
    "@forge/forms": ["packages/forms/src/index.ts"]
  }
}
